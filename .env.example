# Database (MySQL)
# Development
DATABASE_URL="mysql://root:@127.0.0.1:3306/wonderfultoba_dev"

# Production (cPanel)
# DATABASE_URL="mysql://username:password@localhost:3306/database_name"

# JWT secret untuk auth cookie/token (WAJIB diganti di production)
JWT_SECRET="change-this-super-secret-key-in-production"

# API Configuration
NEXT_PUBLIC_API_URL="/api"

# Prisma Configuration
PRISMA_CLIENT_ENGINE_TYPE="library"

# Contact Information
NEXT_PUBLIC_WA_NUMBER="6281323888207"
NEXT_PUBLIC_PHONE="+62 813-2388-8207"
NEXT_PUBLIC_EMAIL_TOUR="tour@wonderfultoba.com"
NEXT_PUBLIC_EMAIL_OUTBOUND="outbound@wonderfultoba.com"

# Site Configuration
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_SITE_NAME="Wonderful Toba"

# Upload Configuration
NEXT_PUBLIC_MAX_FILE_SIZE="5242880"
NEXT_PUBLIC_UPLOAD_PATH="/storage"
