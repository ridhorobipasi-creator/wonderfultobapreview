# ============================================
# PRODUCTION ENVIRONMENT - Wonderful Toba
# Salin file ini ke .env di server cPanel
# ============================================

# Database MySQL (cPanel)
# Format: mysql://cpanel_user:password@localhost:3306/cpanel_database
# Contoh: mysql://medp7341_wt_user:password123@localhost:3306/medp7341_wonderfultoba
DATABASE_URL="mysql://medp7341_wt_user:GANTI_PASSWORD@localhost:3306/medp7341_wonderfultoba"

# JWT Secret - WAJIB diganti! Generate: openssl rand -base64 32
JWT_SECRET="GANTI-DENGAN-RANDOM-STRING-PANJANG-DAN-AMAN-MINIMAL-32-KARAKTER"

# Environment
NODE_ENV="production"

# API Configuration
NEXT_PUBLIC_API_URL="/api"

# Prisma Configuration
PRISMA_CLIENT_ENGINE_TYPE="library"

# Contact Information
NEXT_PUBLIC_WA_NUMBER="6281323888207"
NEXT_PUBLIC_PHONE="+62 813-2388-8207"
NEXT_PUBLIC_EMAIL_TOUR="tour@wonderfultoba.com"
NEXT_PUBLIC_EMAIL_OUTBOUND="outbound@wonderfultoba.com"

# Site Configuration (Production)
NEXT_PUBLIC_SITE_URL="https://wonderfultoba.com"
NEXT_PUBLIC_SITE_NAME="Wonderful Toba"

# Upload Configuration
NEXT_PUBLIC_MAX_FILE_SIZE="5242880"
NEXT_PUBLIC_UPLOAD_PATH="/storage"
